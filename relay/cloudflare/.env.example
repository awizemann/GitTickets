# For local `wrangler dev`, copy this to .dev.vars (Wrangler reads it
# automatically). For production deploys, use `wrangler secret put`.
#
# Same env vars as the Vercel template. See ../vercel/.env.example for the
# detailed setup notes (GitHub App creation, base64-wrapping the PEM, etc.).

GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPO=

GITTICKETS_SHARED_SECRET=

# Optional — R2 public base URL when you've connected a custom domain to
# the bucket. Without this the relay returns r2.dev preview URLs (fine for
# dev; not durable).
# GITTICKETS_R2_PUBLIC_BASE_URL=

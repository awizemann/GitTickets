# GitTickets relay — required configuration
#
# Copy to .env (for `vercel dev`) and set the values below. In production,
# set them via `vercel env add` or the Vercel dashboard.

# ──────────────────────────────────────────────────────────────────────
# GitHub App — the relay holds the installation token and posts as the App.
#
# Create the App at github.com/settings/apps (Issues: Read & Write on ONE
# repo). Install it on the target repo. Note the App ID and Installation
# ID. Generate a private key (.pem file downloads).
#
# IMPORTANT: the PEM file has literal `\n` line breaks. Pasting raw PEM
# into a Vercel env var gets mangled. ALWAYS base64-wrap it first:
#
#   base64 -i private-key.pem | pbcopy          # macOS
#   base64 -w 0 private-key.pem                 # Linux
#
# Then paste the single base64 blob below.
# ──────────────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_INSTALLATION_ID=
GITHUB_OWNER=
GITHUB_REPO=

# ──────────────────────────────────────────────────────────────────────
# Shared secret used by the SDK to sign requests (HMAC-SHA256).
# Generate one: `openssl rand -hex 32`. Paste the same value into the
# Swift app's `SharedSecret(hex:)` initializer.
# ──────────────────────────────────────────────────────────────────────
GITTICKETS_SHARED_SECRET=

# ──────────────────────────────────────────────────────────────────────
# Attachment storage — Vercel Blob.
# In the Vercel dashboard: Storage → Blob → Create. The token is shown once.
# ──────────────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Optional: Upstash Redis for distributed rate limiting and idempotency.
# Without these the relay falls back to per-instance in-memory state
# (acceptable for low-traffic apps; not ideal for multi-region or
# horizontally scaled deployments).
# ──────────────────────────────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────
# Optional tuning knobs (defaults shown).
# ──────────────────────────────────────────────────────────────────────
# GITTICKETS_LABEL=gittickets
# GITTICKETS_IP_HOURLY_LIMIT=30
# GITTICKETS_DEVICE_HOURLY_LIMIT=10
# GITTICKETS_ATTACHMENT_BYTE_LIMIT=5242880
# GITTICKETS_REPLAY_WINDOW_SECONDS=300

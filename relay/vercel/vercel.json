{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/report.ts": {
      "maxDuration": 15
    },
    "api/attachment.ts": {
      "maxDuration": 30,
      "memory": 1024
    },
    "api/my-issues.ts": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/report", "destination": "/api/report" },
    { "source": "/attachment", "destination": "/api/attachment" },
    { "source": "/my-issues", "destination": "/api/my-issues" }
  ]
}

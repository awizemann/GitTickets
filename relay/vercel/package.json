{
  "name": "gittickets-relay-vercel",
  "version": "1.0.0-dev",
  "description": "Vercel Function template for the GitTickets relay. Holds a GitHub App installation token and forwards SDK-signed submissions to the GitHub Issues API.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "jose": "^6.2.0",
    "zod": "^3.23.0"
  },
  "optionalDependencies": {
    "@upstash/redis": "^1.34.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}

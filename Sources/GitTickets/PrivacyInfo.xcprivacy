<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        Privacy manifest for the GitTickets SDK.

        Declarations reflect what the SDK ACTUALLY does, not the worst-case
        capability:

        - No tracking. The SDK never combines its data with third-party data
          to identify a user.
        - No tracking domains. The relay (if used) is a developer-owned
          first-party service; not enumerated here per Apple's guidance.
        - Collected data types: the diagnostics blob (OtherDiagnosticData),
          the per-install UUID (DeviceID), and any user-attached images
          (Photos). All linked to App Functionality only.
        - Required-reasons APIs: just disk-space readout (85F4.1) so the
          diagnostics blob can show available storage.
    -->

    <key>NSPrivacyTracking</key>
    <false/>

    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <key>NSPrivacyCollectedDataTypes</key>
    <array>
        <dict>
            <!-- Diagnostics blob: OS version, app version, device model,
                 free disk, OSLog entries. Shown to the user expanded by
                 default in the form before submission. -->
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherDiagnosticData</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <!-- Per-install UUID generated by DeviceIdentity and stored in
                 the Keychain. Used by the relay for per-device rate limiting
                 and for the "My Issues" view's correlation. NOT IDFA, NOT
                 identifierForVendor — a UUID we generate locally. -->
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeDeviceID</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
        <dict>
            <!-- User-attached images that the user explicitly picks via the
                 attachment button. Only included because the SDK transmits
                 them to the relay; the SDK never opens the photo library on
                 its own. -->
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypePhotosorVideos</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <false/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>
    </array>

    <key>NSPrivacyAccessedAPITypes</key>
    <array>
        <dict>
            <!-- DiagnosticsCollector.freeDiskDescription() reads
                 URL.resourceValues(forKeys: [.volumeAvailableCapacityForImportantUsageKey])
                 to display free disk in the diagnostics blob the user
                 reviews before submission. Reason 85F4.1 covers
                 user-visible disk space displays. -->
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryDiskSpace</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <string>85F4.1</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
